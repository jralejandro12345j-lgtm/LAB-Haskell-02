type Estado = (Int, Int)

capA = 5
capB = 3

transferirAB :: Estado -> Estado
transferirAB (a,b) =
  let espacio = capB - b
      transferido = min a espacio
  in (a - transferido, b + transferido)

transferirBA :: Estado -> Estado
transferirBA (a,b) =
  let espacio = capA - a
      transferido = min b espacio
  in (a + transferido, b - transferido)

heuristica :: Estado -> Int
heuristica (a,_) = abs (4 - a)
