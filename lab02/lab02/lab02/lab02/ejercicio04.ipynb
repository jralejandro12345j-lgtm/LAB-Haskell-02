procesarLecturas :: (Double -> Double) -> [Double] -> [Double]
procesarLecturas f xs = map f xs

crearFiltro :: (a -> Bool) -> ([a] -> [a])
crearFiltro f = filter f

enRango :: Int -> Int -> (Int -> Bool)
enRango a b = \x -> x >= a && x <= b

potenciador :: Int -> (Int -> Int)
potenciador n = \x -> x ^ n
