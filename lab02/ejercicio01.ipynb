-- Recursión

miLength :: [a] -> Int
miLength [] = 0
miLength (_:xs) = 1 + miLength xs

miLast :: [a] -> a
miLast [x] = x
miLast (_:xs) = miLast xs

duplicar :: [Int] -> [Int]
duplicar [] = []
duplicar (x:xs) = (2*x) : duplicar xs

eliminarPares :: [Int] -> [Int]
eliminarPares [] = []
eliminarPares (x:xs)
  | even x = eliminarPares xs
  | otherwise = x : eliminarPares xs

-- Orden superior

miLength2 = length
miLast2 = last
duplicar2 = map (*2)
eliminarPares2 = filter odd
